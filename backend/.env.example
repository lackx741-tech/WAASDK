# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
API_KEY=your-secret-api-key-here

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://mongo:27017/waassdk
MONGODB_DB_NAME=waassdk

# ── Redis (BullMQ job queues) ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
# REDIS_PASSWORD=your-redis-password-if-auth-enabled

# ── JWT (Panel / Affiliate Auth) ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
JWT_EXPIRES_IN=4h
JWT_REFRESH_EXPIRES_IN=7d

# ── Telegram ──────────────────────────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → follow steps → copy the token below
TELEGRAM_BOT_TOKEN=your_bot_token_here
# 2. Start a chat with your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    Copy the "id" from the "chat" object
TELEGRAM_CHAT_ID=your_operator_chat_id
# 3. Set to false to disable all Telegram alerts without removing tokens
TELEGRAM_ALERTS_ENABLED=true

# ── Blockchain / RPC (per-chain env overrides) ────────────────────────────────
# Each chain falls back to its public RPC list in chainNames.js if not set here.
RPC_URL_ETHEREUM=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
RPC_URL_BSC=https://bsc-dataseed.binance.org
RPC_URL_POLYGON=https://polygon-rpc.com
RPC_URL_AVALANCHE=https://api.avax.network/ext/bc/C/rpc
RPC_URL_BASE=https://mainnet.base.org
RPC_URL_ARBITRUM=https://arb1.arbitrum.io/rpc
RPC_URL_OPTIMISM=https://mainnet.optimism.io
RPC_URL_FANTOM=https://rpc.ftm.tools
RPC_URL_GNOSIS=https://rpc.gnosischain.com
RPC_URL_ZKSYNC=https://mainnet.era.zksync.io
RPC_URL_LINEA=https://rpc.linea.build
RPC_URL_SCROLL=https://rpc.scroll.io
RPC_URL_MANTLE=https://rpc.mantle.xyz
RPC_URL_BLAST=https://rpc.blast.io

# RPC pool tuning
RPC_TIMEOUT_MS=5000
RPC_MAX_RETRIES=2

# Private key of the wallet that pays gas for sponsored transactions
# NEVER commit the real key — load via a secret manager in production
SPONSOR_PRIVATE_KEY=your-sponsor-wallet-private-key

# ── Presale Config ────────────────────────────────────────────────────────────
PRESALE_CONTRACT_ADDRESS=0xYourPresaleContract
HARDCAP_ETH=100
SOFTCAP_ETH=20

# ── Portfolio Scanner ─────────────────────────────────────────────────────────
PORTFOLIO_CACHE_TTL_SECONDS=60
PORTFOLIO_SCAN_CONCURRENCY=5

# ── Compiler / Build Engine ───────────────────────────────────────────────────
BUILD_OUTPUT_DIR=./dist/builds
BUILD_RETENTION_DAYS=30

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:5173
