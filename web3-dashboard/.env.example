# ─── WalletConnect / Reown ────────────────────────────────────────────────────
# Get your free project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ─── RPC Endpoints (optional — public RPCs used as fallback) ──────────────────
NEXT_PUBLIC_ETHEREUM_RPC_URL=https://eth.llamarpc.com
NEXT_PUBLIC_POLYGON_RPC_URL=https://polygon.llamarpc.com
NEXT_PUBLIC_BSC_RPC_URL=https://bsc.llamarpc.com
NEXT_PUBLIC_AVALANCHE_RPC_URL=https://avalanche.llamarpc.com
NEXT_PUBLIC_ARBITRUM_RPC_URL=https://arbitrum.llamarpc.com
NEXT_PUBLIC_BASE_RPC_URL=https://base.llamarpc.com

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=WAASDK Dashboard
NEXT_PUBLIC_APP_DESCRIPTION=Web3 SaaS Contract Dashboard
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── Backend API (optional — for saving configs) ──────────────────────────────
NEXT_PUBLIC_BACKEND_URL=https://your-backend.railway.app
