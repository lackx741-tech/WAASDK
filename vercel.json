{
  "_docs": "Values prefixed with @ in 'env' are Vercel secret references. Create them in Vercel Dashboard → Settings → Environment Variables.",
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "framework": "vite",
  "rewrites": [
    { "source": "/",               "destination": "/landing/index.html" },
    { "source": "/dashboard/(.*)", "destination": "/dashboard/$1"       },
    { "source": "/presale/(.*)",   "destination": "/presale/$1"         },
    { "source": "/launch/(.*)",    "destination": "/launch/$1"          }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY"    },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/dist/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "env": {
    "VITE_WALLETCONNECT_PROJECT_ID": "@walletconnect_project_id",
    "VITE_PRESALE_ADDRESS":          "@presale_address",
    "VITE_FACTORY_ADDRESS":          "@factory_address",
    "VITE_PRESALE_CHAIN_ID":         "@presale_chain_id"
  }
}
